// RAG pipeline diagram — render:
//   dot -Tsvg pipeline.dot -o ../assets/pipeline.svg
//   dot -Tpng -Gdpi=160 pipeline.dot -o ../assets/pipeline.png
digraph RAG {
  rankdir=LR;
  bgcolor="#ffffff";
  fontname="DejaVu Sans";
  labelloc="t";
  label=<<FONT POINT-SIZE="24"><B>RAG Pipeline</B></FONT><BR ALIGN="CENTER"/><FONT POINT-SIZE="12" COLOR="#64748b">self-hosted &#183; GPU-split &#183; hybrid retrieval</FONT><BR/> >;
  pad=0.4; nodesep=0.45; ranksep=0.85; splines=spline;

  node [shape=box style="rounded,filled" fontname="DejaVu Sans" fontsize=12
        color="#cbd5e1" penwidth=1.2 margin="0.22,0.14" fontcolor="#0f172a"];
  edge [fontname="DejaVu Sans" fontsize=10 color="#94a3b8" fontcolor="#64748b"
        arrowsize=0.8 penwidth=1.4];

  // ---------- INGESTION (offline) ----------
  subgraph cluster_ingest {
    label=<<FONT POINT-SIZE="13" COLOR="#b45309"><B>  1 · INGESTION</B>  (offline)</FONT>>;
    labeljust="l"; style="rounded,filled,dashed"; fillcolor="#fffaf2"; color="#fcd9a8"; margin=16;
    raw  [label=<<B>documents_raw/</B><BR/><FONT POINT-SIZE="9.5" COLOR="#475569">PDF · DOCX · images</FONT>> fillcolor="#eef2f7"];
    pre  [label=<<B>preprocess.py</B><BR/><FONT POINT-SIZE="9.5" COLOR="#475569">marker → Markdown</FONT>> fillcolor="#ffedd5" color="#f59e0b"];
    md   [label=<<B>documents/</B><BR/><FONT POINT-SIZE="9.5" COLOR="#475569">clean .md</FONT>> fillcolor="#eef2f7"];
    ing  [label=<<B>bulk-ingest.py</B><BR/><FONT POINT-SIZE="9.5" COLOR="#475569">chunk · idempotent</FONT>> fillcolor="#ffedd5" color="#f59e0b"];
    raw -> pre -> md -> ing;
  }

  // ---------- QUERY (live, agentic) ----------
  subgraph cluster_query {
    label=<<FONT POINT-SIZE="13" COLOR="#6d28d9"><B>  2 · QUERY</B>  (live · agentic)</FONT>>;
    labeljust="l"; style="rounded,filled,dashed"; fillcolor="#faf7ff"; color="#ddc9f7"; margin=16;
    user [label=<<B>User / Client</B>> shape=ellipse fillcolor="#ffffff" color="#94a3b8"];
    pg   [label=<<B>PrivateGPT</B>  <FONT POINT-SIZE="9" COLOR="#7c3aed">:8001</FONT><BR/><FONT POINT-SIZE="9.5" COLOR="#475569">agentic RAG · web UI</FONT>> fillcolor="#ede4fd" color="#a78bfa"];
    user -> pg [label="question"];
    pg -> user [label="grounded answer"];
  }

  // ---------- models (GPU) + stores ----------
  llm  [label=<<B>Dolphin-2.9.4-8B</B>  <FONT POINT-SIZE="9" COLOR="#1d4ed8">:8081</FONT><BR/><FONT POINT-SIZE="9.5" COLOR="#475569">llama.cpp · Q8 · GPU A · tools</FONT>> fillcolor="#dbeafe" color="#60a5fa"];
  emb  [label=<<B>Qwen3-Embedding-0.6B</B>  <FONT POINT-SIZE="9" COLOR="#1d4ed8">:8082</FONT><BR/><FONT POINT-SIZE="9.5" COLOR="#475569">1024-d · last-pool · GPU B</FONT>> fillcolor="#dbeafe" color="#60a5fa"];
  qd   [label=<<B>Qdrant server</B>  <FONT POINT-SIZE="9" COLOR="#15803d">:6333</FONT><BR/><FONT POINT-SIZE="9.5" COLOR="#475569">hybrid: dense + sparse (BM25)</FONT>> fillcolor="#dcfce7" color="#4ade80"];

  // ingestion → vectors
  ing -> emb [label="embed chunks"];
  emb -> qd  [label="dense + sparse"];

  // query ↔ retrieval (agentic loop)
  pg -> llm [label="prompt + tools"];
  llm -> pg [label=<<FONT COLOR="#db2777">semantic_search()</FONT>> color="#ec4899" fontcolor="#db2777" penwidth=1.8];
  pg -> qd [label=<<FONT COLOR="#db2777">hybrid retrieve</FONT>> color="#ec4899" fontcolor="#db2777" constraint=false];
  qd -> pg [label=<<FONT COLOR="#db2777">top-k chunks</FONT>> color="#ec4899" fontcolor="#db2777" constraint=false];
}
