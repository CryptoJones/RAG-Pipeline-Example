// RAG pipeline diagram — render with:  dot -Tsvg pipeline.dot -o ../assets/pipeline.svg
//                                       dot -Tpng -Gdpi=150 pipeline.dot -o ../assets/pipeline.png
digraph RAGPipeline {
  rankdir=LR;
  bgcolor="#0d1117";
  fontname="Helvetica,Arial,sans-serif"; fontcolor="#e6edf3"; fontsize=22;
  labelloc="t";
  label="RAG Pipeline — PrivateGPT · Dolphin-8B · Qwen3-Embedding\n(local · GPU-split · hybrid retrieval)";
  pad=0.4; nodesep=0.38; ranksep=0.75;
  node [shape=box style="rounded,filled" fontname="Helvetica,Arial,sans-serif" fontcolor="#0d1117" penwidth=0 margin="0.18,0.10" fontsize=12];
  edge [color="#7d8590" fontname="Helvetica,Arial,sans-serif" fontcolor="#9da7b3" fontsize=10 penwidth=1.6 arrowsize=0.8];

  subgraph cluster_ingest {
    label="①  INGESTION  (offline batch)"; labeljust="l";
    style="rounded,filled"; fillcolor="#161b22"; color="#30363d"; fontcolor="#ffa657"; fontsize=14;
    raw [label="documents_raw/<collection>/\nPDF · DOCX · XLSX · PPTX · images" fillcolor="#d0d7de"];
    pre [label="preprocess.py\nmarker · PDF → Markdown (CPU)" fillcolor="#ffb454"];
    md  [label="documents/<collection>/\nclean .md" fillcolor="#d0d7de"];
    ing [label="bulk-ingest.py\nsha256 manifest · idempotent\nbase64 → POST /v1/artifacts/ingest" fillcolor="#ffb454"];
  }

  subgraph cluster_query {
    label="②  QUERY  (online · agentic)"; labeljust="l";
    style="rounded,filled"; fillcolor="#161b22"; color="#30363d"; fontcolor="#d2a8ff"; fontsize=14;
    user [label="User / Client" shape=ellipse fillcolor="#d0d7de"];
    pgpt [label="PrivateGPT   :8001\n/ui · /v1/messages\nagentic RAG orchestrator" fillcolor="#d2a8ff"];
  }

  subgraph cluster_3060 {
    label="GPU A · 12 GB"; style="rounded,filled"; fillcolor="#0b2a4a"; color="#1f6feb"; fontcolor="#79c0ff"; fontsize=12;
    llm [label="llama.cpp   :8081\nDolphin-2.9.4-llama3.1-8b · Q8_0\nLlama-3.1 tool template" fillcolor="#a5d6ff"];
  }
  subgraph cluster_1080 {
    label="GPU B · 8 GB"; style="rounded,filled"; fillcolor="#0b2a4a"; color="#1f6feb"; fontcolor="#79c0ff"; fontsize=12;
    emb [label="llama.cpp   :8082\nQwen3-Embedding-0.6B · f16\n1024-dim · last-pooling" fillcolor="#a5d6ff"];
  }

  store [label="Qdrant server (podman :6333)\nHYBRID: dense(1024) + sparse(BM25)" fillcolor="#7ee787"];
  sql   [label="SQLite (embedded)\ndoc / index store" fillcolor="#7ee787"];

  // ingestion edges
  raw -> pre -> md -> ing;
  ing -> emb  [label="embed chunks"];
  emb -> store [label="dense vectors"];
  ing -> store [label="sparse vectors\n(fastembed BM25)" style=dashed];
  ing -> sql   [label="metadata" style=dotted];

  // query edges (agentic loop highlighted in pink)
  user -> pgpt [label="question"];
  pgpt -> llm  [label="prompt + tool spec"];
  llm  -> pgpt [label="semantic_search()" color="#f778ba" fontcolor="#f778ba" penwidth=2.2];
  pgpt -> store [label="hybrid retrieve (top_k=10)" color="#f778ba" fontcolor="#f778ba"];
  store -> pgpt [label="ranked chunks" color="#f778ba" fontcolor="#f778ba"];
  pgpt -> llm  [label="context-grounded prompt"];
  llm  -> pgpt [label="grounded answer"];
  pgpt -> user [label="answer + citations"];

  // legend
  subgraph cluster_legend {
    label="legend"; labeljust="l"; style="rounded,filled"; fillcolor="#161b22"; color="#30363d"; fontcolor="#9da7b3"; fontsize=11;
    l_script [label="script" fillcolor="#ffb454"];
    l_model  [label="model (GPU)" fillcolor="#a5d6ff"];
    l_store  [label="storage" fillcolor="#7ee787"];
    l_svc    [label="service" fillcolor="#d2a8ff"];
    l_script -> l_model [style=invis]; l_model -> l_store [style=invis]; l_store -> l_svc [style=invis];
  }
}
